# Supabase — get from: supabase.com > Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase service role key — NEVER expose to browser
# Get from: supabase.com > Project > Settings > API > service_role (JWT starts with eyJ...)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres direct connection (Transaction mode, port 6543)
# Get from: supabase.com > Project > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres.abcdef:password@aws-0-region.pooler.supabase.com:6543/postgres

# Sentry error monitoring (optional)
# Get from: sentry.io > Project > Settings > Client Keys
SENTRY_DSN=https://...@ingest.sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@ingest.sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=tajir

# ── GitHub Actions secrets ──────────────────────────────────────────────────
# Set in: repo Settings > Secrets and variables > Actions
#
# SUPABASE_ACCESS_TOKEN  — supabase.com > Account > Access Tokens
# SUPABASE_PROJECT_REF   — your project reference ID (e.g. npawiohdvkjzfyrxfufm)
# SUPABASE_DB_PASSWORD   — your database password
# VERCEL_DEPLOY_HOOK_URL — Vercel > Project > Settings > Git > Deploy Hooks

# ── Edge Function secrets ────────────────────────────────────────────────────
# Set in: supabase.com > Project > Edge Functions > subscription-transition > Secrets
#
# WEBHOOK_SECRET — shared secret to verify payment webhook signatures
